# Website / Render
PORT=3000
HOST=0.0.0.0
WEB_BASE_URL=https://epi-controle-site.onrender.com
WEB_APP_URL=https://seu-flutter-web.onrender.com
API_BASE_URL=https://epi-controle-app-gupy.onrender.com

# Mercado Pago - use credenciais sandbox em teste e produção em produção
MERCADO_PAGO_ENV=sandbox
MERCADO_PAGO_PUBLIC_KEY=TEST-your-public-key
MERCADO_PAGO_ACCESS_TOKEN=TEST-your-access-token
MERCADO_PAGO_WEBHOOK_SECRET=your-webhook-secret

# IDs dos preapproval plans por tier + ciclo (gere com:
#   node scripts/create-mp-preapproval-plans.js)
# Se ficarem vazios, o backend usa auto_recurring com o valor de cada tier.
MP_PLAN_START_MONTHLY_ID=
MP_PLAN_START_ANNUAL_ID=
MP_PLAN_BUSINESS_MONTHLY_ID=
MP_PLAN_BUSINESS_ANNUAL_ID=
MP_PLAN_CORPORATE_MONTHLY_ID=
MP_PLAN_CORPORATE_ANNUAL_ID=
# OAuth/app metadata (opcional; útil para MCP Server e rotinas administrativas)
MERCADO_PAGO_CLIENT_ID=your-client-id
MERCADO_PAGO_CLIENT_SECRET=your-client-secret
